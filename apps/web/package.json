{
  "name": "@eoneom/web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@eoneom/api-client": "workspace:*",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@tanstack/react-router": "1.120.0",
    "@tanstack/router-cli": "1.120.0",
    "@tanstack/router-generator": "1.120.0",
    "classnames": "^2.3.2",
    "konva": "9.3.22",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "18.2.10",
    "react-scripts": "5.0.1",
    "react-toastify": "^9.1.3",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "router:generate": "node ./scripts/router-generate.cjs",
    "start": "yarn router:generate && PORT=3001 BROWSER=none craco start",
    "build": "yarn router:generate && craco build",
    "test": "yarn router:generate && craco test",
    "test:ci": "yarn router:generate && craco test --watchAll=false",
    "test:ci:coverage": "yarn router:generate && craco test --watchAll=false --coverage",
    "eject": "craco eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@craco/craco": "^7.1.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.12",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@typescript-eslint/eslint-plugin": "^5.51.0",
    "@typescript-eslint/parser": "^5.51.0",
    "eslint": "^8.33.0",
    "eslint-plugin-react": "^7.32.2",
    "typescript": "^4.9.5"
  }
}
