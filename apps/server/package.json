{
  "name": "@eoneom/server",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "start": "node --enable-source-maps dist/index.js | pino-pretty-min",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/node-cron": "3.0.11",
    "@types/uuid": "11.0.0",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "8.57.0",
    "pino-pretty-min": "0.3.2",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@eoneom/api-client": "workspace:^",
    "@typegoose/typegoose": "13.2.1",
    "body-parser": "2.2.2",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "mongoose": "9.5.0",
    "node-cron": "4.2.1",
    "pino": "10.3.1",
    "uuid": "14.0.0",
    "ws": "8.20.0"
  },
  "imports": {
    "#adapter/*": {
      "default": "./dist/adapter/*.js"
    },
    "#app/*": {
      "default": "./dist/app/*.js"
    },
    "#command/*": {
      "default": "./dist/app/command/*.js"
    },
    "#core/*": {
      "default": "./dist/core/*.js"
    },
    "#cron/*": {
      "default": "./dist/cron/*.js"
    },
    "#query/*": {
      "default": "./dist/app/query/*.js"
    },
    "#shared/*": {
      "default": "./dist/shared/*.js"
    },
    "#type/*": {
      "default": "./dist/type/*.js"
    },
    "#web/*": {
      "default": "./dist/web/*.js"
    }
  }
}
