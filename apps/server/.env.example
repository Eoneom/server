# Copy to `.env` in this directory (`apps/server`). Values are loaded on startup
# when you run `yarn workspace @eoneom/server start` (or `yarn server:start` from repo root).

# Optional. Game speed (1 = default): 2 = twice as fast (half wait times).
GAME_TIME_SCALE=1

# MongoDB (defaults match README / containers/docker-compose.yml)
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB_NAME=eoneom

# HTTP API listen port
HTTP_PORT=3000
